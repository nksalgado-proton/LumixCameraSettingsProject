  "field_variants": {
    "C3-2_macro_handheld": {
      "_description": "Variants for C3-2 Macro Handheld depending on lens/accessory combination. Flash: AD100Pro + X3 + ML-CD15 diffuser. Camera settings (f/11, 1/200s, ISO 200, MSHTR) are identical across all variants — only flash mode/power and lens change.",
      "_flash_notes": {
        "ttl_vs_manual": "On G9 MkI, TTL works well at 0.5x-1x magnification. Above 1x (very close), TTL overexposes — switch X3 to Manual. On G9 MkII, TTL overexposes at all macro distances due to Constant Preview interaction — use Manual.",
        "manual_starting_power": "1/128 at macro distances with ML-CD15. Adjust up (1/64) if too dark.",
        "constant_preview": "Must be OFF on G9 MkII for flash modes (C3-2, C3-4). G9 MkI is unaffected.",
        "focus_stacking_with_flash": "Mechanical shutter limits burst to ~2 fps on both G9 bodies. Not practical for fast field stacking. Single shot is the recommended technique.",
        "ad100pro_zoom": "AD100Pro has fixed round head — zoom setting on X3 has no effect."
      },
      "variant_1": {
        "name": "90mm bare, handheld (Costa Rica baseline for MkI)",
        "lens": "Olympus M.Zuiko 90mm f/3.5 Macro IS PRO",
        "use_case": "Frogs, snakes, lizards, tarantulas, larger insects. Safer working distance (~11cm at 1:1).",
        "flash_mode": "TTL at 0.5x-1x, Manual 1/128 at >1x",
        "flash_adjust_ttl": "±0 to +0.3 (more working distance than 60mm)",
        "notes": "Dual IS (lens + body) on MkI. Best all-round macro lens for Costa Rica herps."
      },
      "variant_2": {
        "name": "60mm bare, handheld (swap variant)",
        "lens": "Olympus M.Zuiko 60mm f/2.8 Macro",
        "use_case": "Small insects, glass frogs, subjects needing true 1:1. Closer working distance (~7cm at 1:1).",
        "flash_mode": "TTL at 0.5x-1x, Manual 1/128 at >1x",
        "flash_adjust_ttl": "±0",
        "notes": "Baseline configuration as stored in C3-2 on both cameras."
      },
      "variant_3": {
        "name": "60mm + Raynox DCR-250, handheld",
        "lens": "Olympus 60mm + Raynox DCR-250 diopter",
        "use_case": "Very small subjects, >1:1 magnification",
        "flash_mode": "Manual 1/128 (very close distance, TTL overexposes)",
        "notes": "May need to back flash away slightly if 1/128 still too bright"
      },
      "variant_4": {
        "name": "90mm + MC-20, handheld (MkII only, not for Costa Rica)",
        "lens": "Olympus 90mm + MC-20 2x teleconverter",
        "use_case": "Extreme magnification, effective 180mm f/7 macro",
        "flash_mode": "Manual 1/64 to 1/128",
        "flash_adjust_ttl": "+0.7 to +1.3 if using TTL",
        "iso_sensitivity": "200-400",
        "notes": "2 stops lost to TC. AD100Pro has enough power at macro distances. MkII only — Constant Preview must be OFF."
      },
      "variant_5": {
        "name": "90mm bare + Focus Stacking, tripod (MkII C3-4)",
        "lens": "Olympus 90mm f/3.5 Macro IS PRO",
        "use_case": "Static subjects, controlled environment",
        "changes": {
          "bracketing": "ON - Focus Bracketing",
          "aperture": "f/8",
          "iso_sensitivity": 400,
          "image_stabilizer": "OFF",
          "shutter_delay": "2s"
        },
        "flash_mode": "Manual 1/128 to 1/64",
        "notes": "~2 fps with mechanical shutter. 20 frames takes ~10 seconds. Subject must be completely still."
      },
      "variant_6": {
        "name": "90mm + MC-20 + Focus Stacking, tripod required (MkII C3-4)",
        "lens": "Olympus 90mm + MC-20",
        "changes": {
          "bracketing": "ON - Focus Bracketing",
          "aperture": "f/7 (wide open, effective ~f/14)",
          "iso_sensitivity": "400-800",
          "image_stabilizer": "OFF",
          "shutter_delay": "2s"
        },
        "flash_mode": "Manual 1/64 to 1/32",
        "notes": "Most demanding setup. More flash power needed, slower recycle. Tripod mandatory."
