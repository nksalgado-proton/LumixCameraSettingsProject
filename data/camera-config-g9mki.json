  "fn_buttons": {
    "_description": "1 button changed. G9 MkI has NO dedicated AF-ON or Q button — Fn1 and Fn2 assignments are MANDATORY.",
    "changed": [
      {
        "button": "Fn1",
        "location": "Back panel, next to AF Mode button (42)",
        "assignment": "AF-ON",
        "rationale": "MANDATORY — G9 MkI has no dedicated AF-ON button. Backbone of back-button focus."
      }
    ],
    "defaults_kept": [
      {"button": "Fn2 (52)", "assignment": "Q.MENU", "rationale": "G9 MkI has no dedicated Q button — must stay as Q.MENU"},
      {"button": "Fn3 (36)", "assignment": "LVF/Monitor Switch", "rationale": "Back panel, top-left"},
      {"button": "Fn4 (11)", "assignment": "AF-Point Scope", "rationale": "Front, near grip"},
      {"button": "Fn5 (12)", "assignment": "Preview", "rationale": "Front, depth-of-field preview"},
      {"button": "Fn Lever (29)", "assignment": "Silent Mode", "rationale": "Flip to MODE2 for Silent Mode toggle — intuitive for wife"},
      {"button": "+/- (4)", "assignment": "Exposure Comp.", "rationale": "Top panel"},
      {"button": "ISO (5)", "assignment": "Sensitivity", "rationale": "Top panel"},
      {"button": "WB (6)", "assignment": "White Balance", "rationale": "Top panel"},
      {"button": "Video rec (2)", "assignment": "Video Record", "rationale": "Top panel"},
      {"button": "Fn11-Fn15 (41)", "assignment": "D.FOCUS Movement", "rationale": "Joystick moves AF point"},
      {"button": "Fn16-Fn19 (46)", "assignment": "OFF", "rationale": "Cursor buttons not assigned"}
    ],
    "notes": [
      "Touch Tab is OFF — Fn6-Fn10 (touch icons) not accessible",
      "G9 MkI has NO dedicated AF-ON button — Fn1 assignment is mandatory",
      "G9 MkI has NO dedicated Q button — Fn2 must stay as Q.MENU",
      "G9 MkI HAS Function Lever for Silent Mode (MkII does not)"
    ]
  },

