# OS files
.DS_Store
Thumbs.db
desktop.ini

# Large binary files — camera/flash manuals (keep locally, too large for git)
reference/manuals/*.pdf

# Legacy PDFs and presentations (keep locally)
reference/legacy/**/*.pdf
reference/legacy/**/*.pptx

# Binary libraries
*.dll
*.lib
*.exe

# CACHEDIR tags
CACHEDIR.TAG
