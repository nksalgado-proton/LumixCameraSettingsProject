# Python virtual environments
.venv/
venv/
ENV/

# Python caches
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# IDE / editor files
.idea/
.vscode/
*.swp
*.swo
*~
.claude/

